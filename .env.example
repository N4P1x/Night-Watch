# DWTIP - Dark Web Threat Intelligence Platform
# Environment Configuration

# API Configuration
API_URL=http://localhost:8000

# Scraper Authentication (used by scrape_tor.py)
SCRAPER_USERNAME=admin
SCRAPER_PASSWORD=admin123
ADMIN_PASSWORD=admin123  # Fallback for backwards compatibility

# DeepDark CTI Path (can be absolute or relative)
DEEPDARKCTI_PATH=

# Database
DATABASE_URL=postgresql://dwtip:dwtip_secure_password@localhost:5432/dwtip
MONGODB_URL=mongodb://localhost:27017/dwtip
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-this-to-a-secure-random-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Tor Configuration
TOR_PROXY=socks5h://localhost:9050
TOR_CONTROL=localhost:9051
TOR_PASSWORD=
TOR_CIRCUIT_ROTATE_INTERVAL=300

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=

# Monitoring
SENTRY_DSN=
LOG_LEVEL=INFO
MAX_WORKERS=4
SCRAPE_INTERVAL_MINUTES=15

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Fernet key for credential encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=
