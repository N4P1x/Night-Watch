# DWTIP Production Environment Configuration
# Copy this file to .env and update values for production

# ===================
# Database Configuration
# ===================
POSTGRES_PASSWORD=generate-secure-password-here
DATABASE_URL=postgresql://dwtip:${POSTGRES_PASSWORD}@dwtip-postgres:5432/dwtip
MONGODB_URL=mongodb://dwtip-mongodb:27017/dwtip
REDIS_URL=redis://dwtip-redis:6379/0

# ===================
# Security
# ===================
SECRET_KEY=generate-64-character-random-string
ENVIRONMENT=production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# ===================
# CORS & Networking
# ===================
ALLOWED_ORIGINS=https://your-domain.com,https://app.your-domain.com

# ===================
# Tor Configuration
# ===================
TOR_PROXY=socks5://dwtip-tor:9050
TOR_CONTROL=dwtip-tor:9051
TOR_PASSWORD=your-tor-control-password

# ===================
# Scraper Settings
# ===================
SCRAPER_USERNAME=scraper
SCRAPER_PASSWORD=generate-secure-scraper-password
MAX_WORKERS=8
SCRAPE_INTERVAL_MINUTES=30

# ===================
# Email (Alerts)
# ===================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
ALERT_EMAIL=alerts@your-domain.com

# ===================
# Telegram (Optional)
# ===================
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your-telegram-api-hash

# ===================
# Monitoring
# ===================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
LOG_LEVEL=INFO
GRAFANA_USER=admin
GRAFANA_PASSWORD=generate-secure-grafana-password
